NODE_ENV=development
PORT=3000

# Azure SQL — map from Key Vault in App Service
DB_SERVER=your-server.database.windows.net
DB_NAME=rental
DB_USER=app
DB_PASSWORD=change-me
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

# Microsoft Entra External ID (CIAM) or B2C — validates SPA access tokens sent to this API
# Use the Application (client) ID of the app registration that EXPOSES the API scope your SPA requests.
# Issuer and JWKS must match tokens from your authority (External ID tenant / user flow).
AZURE_AD_B2C_TENANT=contoso
AZURE_AD_B2C_POLICY=B2C_1_signupsignin
AZURE_AD_B2C_CLIENT_ID=your-api-app-registration-client-id
# Issuer URL from Entra metadata (token `iss` claim must match).
AZURE_AD_B2C_ISSUER=https://your-tenant.ciamlogin.com/your-tenant-id/v2.0/
# If empty, set explicitly to your tenant JWKS endpoint (required for production validation).
AZURE_AD_B2C_JWKS_URI=https://your-tenant.ciamlogin.com/your-tenant-id/discovery/v2.0/keys

# Stripe (use Key Vault in prod)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Azure Blob
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_EQUIPMENT=equipment
AZURE_STORAGE_CONTAINER_CONDITIONS=conditions
AZURE_STORAGE_CONTAINER_DISPUTES=disputes
AZURE_STORAGE_CONTAINER_DELIVERIES=deliveries

# Service Bus
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_TOPIC_RENTAL_EVENTS=rental-events

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Dev-only JWT (when not using B2C JWKS)
JWT_DEV_SECRET=change-in-local-dev-only

STRIPE_APPLICATION_FEE_BPS=1000
PLATFORM_ADMIN_SUBS=
PLATFORM_BUSINESS_OWNER_SUBS=
PLATFORM_BUSINESS_MANAGER_SUBS=
